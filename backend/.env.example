# Servidor
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=sua_chave_jwt_super_secreta_troque_em_producao
JWT_SA_SECRET=outra_chave_jwt_exclusiva_superadmin_troque_em_producao
JWT_EXPIRES_IN=7d

# Database
DB_PATH=./data/secretaria.db
BACKUP_DIR=./data/backups

# Stripe
STRIPE_SECRET_KEY=sk_test_sua_chave_stripe_aqui
STRIPE_WEBHOOK_SECRET=whsec_sua_chave_webhook_aqui
STRIPE_PRICE_BASICO=price_basico_id
STRIPE_PRICE_PROFISSIONAL=price_profissional_id
STRIPE_PRICE_PREMIUM=price_premium_id

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
SMTP_PASS=sua_app_password_gmail_aqui
SMTP_FROM=noreply@seudominio.com.br
# E-mail de destino para notificações de aniversário (padrão: admin da igreja)
NOTIFY_EMAIL=

# App
APP_NAME=SecretariaSistema
APP_URL=https://secretariasistema.com.br
